# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Set to true to mirror log output to the in-app log panel (requires GUI)
LOG_TO_GUI=false

# ─── Hardware mode ────────────────────────────────────────────────────────────
# Set to true to run with simulated sensors/actuators (no physical Arduino needed)
MOCK_HARDWARE=false

# ─── Serial connection ────────────────────────────────────────────────────────
# AUTODETECT scans USB ports for an Arduino; or specify an exact port, e.g. COM3
SERIAL_PORT=AUTODETECT
SERIAL_BAUD=115200

# ─── Arduino pin assignments ──────────────────────────────────────────────────
# DHT11 DATA wire → digital pin
PIN_DHT=4

# YL-69 analog output → analog pin index (1 = A1)
PIN_SOIL_ANALOG=1

# Fan relay signal wire → digital pin (active HIGH)
PIN_FAN_RELAY=7

# Micro servo signal wire → PWM pin
PIN_SERVO=9

# RGB LED PWM pins
# Pins 2, 3, 5 use Timer 3 — safe alongside the Servo library (which uses Timer 1).
# Do NOT use pins 11 or 12: the Servo library disables analogWrite on them.
PIN_LED_R=2
PIN_LED_G=3
PIN_LED_B=5

# Set to true if the RGB LED has a common-anode wiring (inverts PWM duty cycle)
LED_COMMON_ANODE=false

# ─── Soil moisture ADC calibration ───────────────────────────────────────────
# Raw ADC values (0–1023) from YL-69: measure in water (wet) and dry air (dry)
SOIL_ADC_WET=300
SOIL_ADC_DRY=900

# ─── Timing ───────────────────────────────────────────────────────────────────
# How often to read sensors and check thresholds, in milliseconds (minimum 500)
SENSOR_POLL_MS=1000

# IANA timezone name used by the LED scheduler for local time calculations
TIMEZONE=Europe/Minsk
