# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Set to true to mirror log output to the in-app log panel (requires GUI)
LOG_TO_GUI=false

# ─── Hardware mode ────────────────────────────────────────────────────────────
# Set to true to run with simulated sensors/actuators (no physical Arduino needed)
MOCK_HARDWARE=false

# ─── Serial connection ────────────────────────────────────────────────────────
# AUTODETECT scans USB ports for an Arduino; or specify an exact port, e.g. COM4
SERIAL_PORT=AUTODETECT
SERIAL_BAUD=115200

# ─── Arduino pin assignments ──────────────────────────────────────────────────
# DHT11 DATA → D4 (VCC on 3.3V on the bench)
PIN_DHT=4

# YL-69 analog output → analog pin index (1 = A1)
PIN_SOIL_ANALOG=1

# Fan relay IN → D8 (JQC3F-05VDC-C, active LOW)
PIN_FAN_RELAY=8

# Continuous-rotation servo signal → D9
PIN_SERVO=9

# Reserved wire on D7 for a future single LED (+ 220 Ω resistor)
PIN_LED_FUTURE=7

# RGB pins — used only if LED_HARDWARE_ENABLED=true (default: GUI simulation only)
PIN_LED_R=2
PIN_LED_G=3
PIN_LED_B=5
LED_COMMON_ANODE=false

# false = LED panel is simulated; no LED commands sent to Arduino
LED_HARDWARE_ENABLED=false

# true = relay ON when IN is LOW (JQC3F bench module)
RELAY_ACTIVE_LOW=true

# Continuous servo S2: stop / irrigation spin (clockwise on the bench)
SERVO_STOP_ANGLE=90
SERVO_OPEN_ANGLE=0

# ─── Soil moisture ADC calibration ───────────────────────────────────────────
# Raw ADC values (0–1023) from YL-69: measure in water (wet) and dry air (dry)
SOIL_ADC_WET=300
SOIL_ADC_DRY=900

# ─── Timing ───────────────────────────────────────────────────────────────────
# How often to read sensors and check thresholds, in milliseconds (minimum 500)
SENSOR_POLL_MS=1000

# IANA timezone name used by the LED scheduler for local time calculations
TIMEZONE=Europe/Minsk
